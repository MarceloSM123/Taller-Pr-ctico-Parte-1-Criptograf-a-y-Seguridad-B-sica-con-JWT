  "item": [
    {
      "name": "POST Registrar Usuario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"voluntario_carlos\",\n  \"password\": \"mi_clave_secreta_123\",\n  \"rol\": \"ADMIN\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/auth/registrar",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "registrar"]
        }
      }
    },
    {
      "name": "POST Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"voluntario_carlos\",\n  \"password\": \"mi_clave_secreta_123\"\n}"
        },
        "url": {
